DATABASE_URL=sqlite://persistent-agent.db?mode=rwc
BIND_ADDR=127.0.0.1:8080
SCHEDULER_INTERVAL_SECONDS=30
SCHEDULER_LEASE_SECONDS=300
SCHEDULER_WORKER_CAPACITY=1
SCHEDULER_MAX_ATTEMPTS=1
# Optional. Omit to keep worker memory candidates pending for manual review.
MEMORY_AUTO_APPROVE_CONFIDENCE=

# Optional. When unset, the server uses the deterministic stub worker.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
# Optional. Defaults to harness. Use llm_json to temporarily fall back to the legacy single-response worker.
PERSISTENT_AGENT_WORKER_MODE=harness
